generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions=[vector]
}

// ─── ENUMS ─────────────────────────────────────────────────────────────
enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

// ─── MODELS ────────────────────────────────────────────────────────────

model User {
  id                String          @id @default(uuid())
  name              String
  phone             String          @unique
  password          String
  role              String          @default("RETAILER")
  city              String 
  
  profilePic        String?  
  businessName      String?  
  businessType      String?  
  address           String?  
  pushToken         String?  
  
  status       String        @default("ACTIVE")
  properties        Property[]      @relation("UserProperties") 
  favoriteProperties Property[]     @relation("UserFavorites") 
  products          Product[]       @relation("UserProducts")
  buyerNegotiations Negotiation[]   @relation("BuyerNegotiations")
  sellerNegotiations Negotiation[]  @relation("SellerNegotiations")
  offersSent        Offer[]         @relation("UserOffers")
  buyerShipments    Shipment[]      @relation("BuyerShipments")
  sellerShipments   Shipment[]      @relation("SellerShipments")
  
  inventories       Inventory[]
  notifications     Notification[]
  purchases         Purchase[] @relation("BuyerPurchases")
  sellerPurchases   Purchase[] @relation("SellerPurchases")
  // 🚨 NEW: Payment Links for Khata System
  paymentsMade      Payment[]       @relation("PaymentsMade")
  paymentsReceived  Payment[]       @relation("PaymentsReceived")
  buyerDemands      BuyerDemand[]   @relation("BuyerDemands")

  embedding   Unsupported("vector(768)")?
  averageRating     Float           @default(0.0)
  totalReviews      Int             @default(0)

  buyerRooms     ChatRoom[]    @relation("BuyerRooms")
  sellerRooms    ChatRoom[]    @relation("SellerRooms")
  chatMessages   ChatMessage[]

  reviewsGiven      Review[]        @relation("ReviewsGiven")
  reviewsReceived   Review[]        @relation("ReviewsReceived")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum MessageType {
  TEXT
  IMAGE     // For sharing photos of the inventory or transport
  DOCUMENT  // For sharing quality certificates or invoices
  SYSTEM    // For automated alerts (e.g., "Wholesaler sent a new offer")
}

model ChatRoom {
  id          String        @id @default(uuid())
  productId   String?       
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  buyerId     String
  buyer       User          @relation("BuyerRooms", fields: [buyerId], references: [id])
  
  sellerId    String
  seller      User          @relation("SellerRooms", fields: [sellerId], references: [id])
  
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([buyerId, sellerId, productId]) 
}

model ChatMessage {
  id          String      @id @default(uuid())
  roomId      String
  room        ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  // Optional: System messages won't have a senderId
  senderId    String?     
  sender      User?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  
  type        MessageType @default(TEXT)
  text        String      // Holds standard text, a file URL, or a system notification
  
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

model Review {
  id          String   @id @default(uuid())
  rating      Int      // e.g., 1 to 5
  feedback    String?  @db.Text
  
  reviewerId  String
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  
  revieweeId  String
  reply       String?  @db.Text
  reviewee    User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  
  createdAt   DateTime @default(now())

  @@unique([reviewerId, revieweeId]) 
}

model Document {
  id        String   @id @default(uuid())
  text      String
  metadata  Json
  embedding Unsupported("vector(768)")
}

model Property {
  id           String   @id @default(uuid())
  ownerId      String
  owner        User     @relation("UserProperties", fields: [ownerId], references: [id])
  title        String
  description  String?
  propertyType String   
  listingType  String   
  price        Float    
  deposit      Float?   
  areaSqFt     Float
  address      String
  city         String
  state        String
  images       String[] 
  status       String   @default("AVAILABLE")
  favoritedBy  User[]   @relation("UserFavorites")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id           String        @id @default(uuid())
  sellerId     String
  seller       User          @relation("UserProducts", fields: [sellerId], references: [id])
  name         String
  description  String?
  category     String 
  mandiName    String?
  price        Float 
  unit         String        @default("KG") 
  stock        Float 
  images       String[] 
  isAvailable  Boolean       @default(true)
  negotiations Negotiation[]
  expiryDate   DateTime 
  chatRooms      ChatRoom[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  shipment     Shipment[]
}

model Negotiation {
  id        String   @id @default(uuid())
  buyerId   String
  sellerId  String
  productId String? 
  status    String   @default("ACTIVE") 
  buyer     User     @relation("BuyerNegotiations", fields: [buyerId], references: [id])
  seller    User     @relation("SellerNegotiations", fields: [sellerId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])
  offers    Offer[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shipments Shipment?
}

model Offer {
  id            String      @id @default(uuid())
  negotiationId String
  senderId      String
  price         Float
  message       String?
  status        String      @default("PENDING")
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id])
  sender        User        @relation("UserOffers", fields: [senderId], references: [id])
  createdAt     DateTime    @default(now())
}

model Inventory {
  id         String   @id @default(uuid())
  userId     String   
  user       User     @relation(fields: [userId], references: [id]) 
  name       String   
  category   String
  buyPrice   Float    
  quantity   Int      
  unit       String  
  expiryDate DateTime? 
  sales      Sale[]   
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
} 

model Sale {
  id            String        @id @default(uuid())
  inventoryId   String
  inventory     Inventory     @relation(fields: [inventoryId], references: [id])
  sellPrice     Float    
  quantity      Int      
  profit        Float    
  
  // 🚨 NEW: Khata Credit System Fields
  buyerName     String?       // Fallback for offline cash customers
  buyerPhone    String?
  paymentStatus PaymentStatus @default(PAID)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)
  payments      Payment[]

  soldAt        DateTime      @default(now())
}

model Shipment {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  quantity      Float    
  negotiationId String?      @unique
  negotiation   Negotiation? @relation(fields: [negotiationId], references: [id])
  buyerId       String
  sellerId      String
  buyer         User         @relation("BuyerShipments", fields: [buyerId], references: [id])
  seller        User         @relation("SellerShipments", fields: [sellerId], references: [id])
  driverName    String?
  driverPhone   String?  
  vehicleNumber String?
  transportCost Float        @default(0) 
  status        String       @default("PENDING") 
  currentLat    Float?
  currentLng    Float?
  lastUpdated   DateTime     @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") 
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Purchase {
  id            String        @id @default(uuid())
  
  // 1. The Buyer (You)
  userId        String
  user          User          @relation("BuyerPurchases", fields: [userId], references: [id], onDelete: Cascade)
  
  // 2. The Seller (Supplier)
  sellerId      String?
  seller        User?         @relation("SellerPurchases", fields: [sellerId], references: [id])

  name          String
  quantity      Int
  unit          String
  buyPrice      Float
  total         Float

  paymentStatus PaymentStatus @default(PAID)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)
  payments      Payment[]

  createdAt     DateTime      @default(now())
}
model Payment {
  id          String    @id @default(uuid())
  amount      Float
  method      String    // e.g., "CASH", "UPI", "BANK_TRANSFER", "PLATFORM_CREDIT"
  date        DateTime  @default(now())

  // 1. THE PERSON GIVING THE MONEY
  buyerId     String
  buyer       User      @relation("PaymentsMade", fields: [buyerId], references: [id])

  // 2. THE PERSON RECEIVING THE MONEY
  sellerId    String
  seller      User      @relation("PaymentsReceived", fields: [sellerId], references: [id])

  // 3. TRANSACTION LINKS (To know what they are paying for)
  purchaseId  String?
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  
  saleId      String?
  sale        Sale?     @relation(fields: [saleId], references: [id])
}
model BuyerDemand {
  id              String      @id @default(uuid())
  buyerId         String
  buyer                 User     @relation("BuyerDemands", fields: [buyerId], references: [id])
  cropName        String      
  isCustomCrop    Boolean     @default(false) 
  
  region          String
  status          String      @default("ACTIVE") // ACTIVE or CLOSED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model KnowledgeDocument {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  roleTarget  String   
  embedding   Unsupported("vector(768)") 
  
  createdAt   DateTime @default(now())
}